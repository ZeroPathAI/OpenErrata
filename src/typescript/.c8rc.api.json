{
  "all": true,
  "src": ["src"],
  "include": ["src/lib/**", "src/routes/**"],
  "exclude": [
    "**/*.test.ts",
    "**/test/**",
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/.svelte-kit/**",
    "**/prisma/migrations/**",
    "src/lib/generated/**"
  ],
  "check-coverage": true,
  "lines": 80,
  "branches": 80,
  "functions": 85,
  "statements": 80
}
